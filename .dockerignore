# ============================================
# GIT
# ============================================
.git
.gitignore

# ============================================
# NODE (don't copy node_modules — npm ci in Docker)
# ============================================
node_modules
frontend/node_modules

# ============================================
# PYTHON (don't copy venvs)
# ============================================
venv312
venv
.venv
__pycache__
*.pyc
*.pyo
.pytest_cache
backend/__pycache__
backend/app/__pycache__

# ============================================
# IDE
# ============================================
.vscode
.idea
*.swp
*.swo

# ============================================
# LOGS & DATA (created at runtime)
# ============================================
logs/
backend/logs/
backend/data/
data/

# ============================================
# DEV & DOC FILES
# ============================================
*.md
*.pdf
*.txt
!backend/requirements.txt
!frontend/package.json
!frontend/package-lock.json

# ============================================
# DOCKER (don't nest docker files)
# ============================================
docker-compose.yml
backend/Dockerfile
frontend/Dockerfile
backend/.env
backend/.env.local
backend/.env.production
backend/.env.example

# ============================================
# TESTS
# ============================================
backend/tests/
frontend/tests/

# ============================================
# OS FILES
# ============================================
.DS_Store
Thumbs.db
